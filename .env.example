# Sapien Web (SaaS) — variáveis do build web (Vite). Copie para ".env.local".
# Pegue estes valores em: Supabase → Project Settings → API.
# A "anon key" é PÚBLICA (pode ir pro front); NUNCA use a "service_role" no front.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica
